{
  "name": "mymun-platform",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "db:reset:public": "prisma db execute --file prisma/scripts/reset-public-supabase.sql",
    "db:migrate:fresh": "npm run db:reset:public && npm run prisma:migrate:deploy",
    "db:seed": "npx tsx prisma/seed.ts",
    "bootstrap:admin": "npx tsx scripts/bootstrap-super-admin.ts",
    "create:cashfree-test-mun": "npx tsx scripts/create-cashfree-test-conference.ts",
    "db:reset": "prisma migrate reset --force",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:prod": "playwright test e2e/production-smoke.spec.ts",
    "test:payment-flow": "node scripts/test-payment-flow.mjs",
    "test:webhook": "node scripts/simulate-cashfree-webhook.mjs",
    "verify:env": "node scripts/verify-production-env.mjs",
    "verify:prod-deploy": "node scripts/verify-production-deploy.mjs",
    "pre-launch:check": "node scripts/pre-launch-check.mjs",
    "brand:generate": "node scripts/generate-brand-pngs.mjs",
    "favicon:generate": "node scripts/generate-favicon.mjs",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare build && wrangler dev",
    "cf:deploy": "opennextjs-cloudflare build && wrangler deploy"
  },
  "dependencies": {
    "@cashfreepayments/cashfree-js": "^1.0.7",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@react-three/postprocessing": "^3.0.4",
    "@sentry/nextjs": "^10.52.0",
    "@studio-freight/lenis": "^1.0.42",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "cashfree-pg": "^6.0.4",
    "framer-motion": "^12.38.0",
    "html5-qrcode": "^2.3.8",
    "jose": "^6.2.2",
    "jspdf": "^4.2.1",
    "next": "16.2.3",
    "pg": "^8.16.3",
    "prisma": "^7.7.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.2",
    "three": "^0.184.0",
    "zod": "^4.4.3"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.6.0",
    "@playwright/test": "^1.51.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "jsdom": "^26.1.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.20.0",
    "typescript": "^5",
    "vitest": "^3.2.4",
    "wrangler": "^4.15.2"
  }
}
