// Tidingz — PostgreSQL (Supabase). Use pooled DATABASE_URL at runtime; DIRECT_URL for migrations.
// RLS is enabled on app tables in migration `20260510140000_supabase_rls_and_extensions` (PostgREST lockdown; Prisma owner bypasses).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  DELEGATE
  ORGANIZER
  ADMIN
}

enum RegistrationStatus {
  PENDING
  ALLOTTED
  WAITLISTED
  REJECTED
}

enum PassStatus {
  ISSUED
  REVOKED
}

enum CommitteeVisibility {
  PUBLIC
  PRIVATE
}

enum EventPartnershipStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

enum EventStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
  CANCELLED
}

enum NotificationType {
  PASS_RELEASED
  CHECKED_IN
  APP_STATUS
  PAYMENT_CONFIRMED
  TEAM_INVITE
  ANNOUNCEMENT
  OTHER
}

enum PaymentProvider {
  FREE
  MANUAL
}

enum PaymentIntentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum TeamRole {
  LEAD_ORGANIZER
  USG
  LOGISTICS_HEAD
  COMMITTEE_HEAD
  STAFF
}

model User {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  name                   String
  passwordHash           String?
  role                   UserRole                @default(DELEGATE)
  sessionVersion         Int                     @default(0)
  failedLoginAttempts    Int                     @default(0)
  lockedUntil            DateTime?
  deletedAt              DateTime?
  emailVerified          Boolean                 @default(false)
  registrations          Registration[]
  emailVerificationTokens EmailVerificationToken[]
  checkins               Checkin[]               @relation("CheckinBy")
  notifications          Notification[]
  passwordResetTokens    PasswordResetToken[]
  createdPartnerships    EventPartnership[]      @relation("PartnershipCreatedBy")
  respondedPartnerships  EventPartnership[]      @relation("PartnershipRespondedBy")
  ownedEvents            Event[]                 @relation("EventOwner")
  eventTeamMemberships   EventTeamMember[]
  auditLogs              AuditLog[]
  confirmedPaymentIntents PaymentIntent[]        @relation("PaymentConfirmedBy")
  delegationOwned        Delegation[]            @relation("DelegationOwner")
  delegationMembers      DelegationMember[]
  conferenceReviews      ConferenceReview[]
  notificationPreferences UserNotificationPreference[]
  /** Delegate-facing profile fields (JSON) — source of truth vs client-only localStorage. */
  delegateProfile        Json?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model Event {
  id                      String                  @id
  title                   String
  startDate               DateTime
  endDate                 DateTime
  slug                    String?                 @unique
  status                  EventStatus             @default(DRAFT)
  timezone                String?
  currency                String?                 @default("INR")
  coverImageUrl           String?
  ownerUserId             String?
  deletedAt               DateTime?
  organizerConfig         OrganizerConferenceConfig?
  registrations           Registration[]
  passes                  DelegatePass[]
  checkins                Checkin[]
  notifications           Notification[]
  outgoingPartnerships    EventPartnership[]      @relation("PartnershipSourceEvent")
  incomingPartnerships    EventPartnership[]      @relation("PartnershipTargetEvent")
  teamMembers             EventTeamMember[]
  auditLogs               AuditLog[]
  awards                  ConferenceAward[]
  reviews                 ConferenceReview[]
  delegations             Delegation[]
  owner                   User?                   @relation("EventOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  @@index([status, startDate])
}

model EventTeamMember {
  id           String    @id @default(cuid())
  eventId      String
  userId       String
  role         TeamRole  @default(STAFF)
  permissions  Json?
  invitedAt    DateTime?
  acceptedAt   DateTime?
  event        Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model EventPartnership {
  id                String                 @id @default(cuid())
  sourceEventId     String
  targetEventId     String
  status            EventPartnershipStatus @default(PENDING)
  createdByUserId   String
  respondedByUserId String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  sourceEvent       Event                  @relation("PartnershipSourceEvent", fields: [sourceEventId], references: [id], onDelete: Cascade)
  targetEvent       Event                  @relation("PartnershipTargetEvent", fields: [targetEventId], references: [id], onDelete: Cascade)
  createdBy         User                   @relation("PartnershipCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  respondedBy       User?                  @relation("PartnershipRespondedBy", fields: [respondedByUserId], references: [id], onDelete: SetNull)

  @@unique([sourceEventId, targetEventId], map: "EventPartnership_source_target_key")
  @@index([sourceEventId])
  @@index([targetEventId])
}

/// Partial unique in DB: at most one row per (userId, eventId) where deletedAt IS NULL — see migration `Registration_userId_eventId_active_key`.
model Registration {
  id                String             @id
  userId            String
  eventId           String
  categoryName      String
  committeeName     String?
  portfolioName     String?
  amount            Decimal            @db.Decimal(12, 2)
  paid              Boolean            @default(false)
  status            RegistrationStatus @default(PENDING)
  allottedAt        DateTime?
  checkedIn         Boolean            @default(false)
  checkedInAt       DateTime?
  deletedAt         DateTime?
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  event             Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  pass              DelegatePass?
  checkins          Checkin[]
  notifications     Notification[]
  paymentIntent     PaymentIntent?
  applicationAnswers ApplicationAnswer[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([eventId])
  @@index([userId])
  @@index([eventId, deletedAt])
}

model PaymentIntent {
  id                String               @id @default(cuid())
  registrationId    String               @unique
  provider          PaymentProvider
  amount            Decimal              @db.Decimal(12, 2)
  currency          String               @default("INR")
  status            PaymentIntentStatus    @default(PENDING)
  confirmedAt       DateTime?
  confirmedByUserId String?
  reference         String?
  notes             String?
  raw               Json?
  registration      Registration         @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  confirmedBy       User?                @relation("PaymentConfirmedBy", fields: [confirmedByUserId], references: [id], onDelete: SetNull)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
}

model DelegatePass {
  id             String       @id @default(cuid())
  registrationId String       @unique
  eventId        String
  qrTokenHash    String
  releaseAt      DateTime
  issuedAt       DateTime     @default(now())
  status         PassStatus   @default(ISSUED)
  deletedAt      DateTime?
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  event          Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  checkins       Checkin[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([eventId])
}

model Checkin {
  id             String       @id @default(cuid())
  passId         String
  registrationId String
  eventId        String
  checkedInById  String?
  deviceMeta     String?
  checkedInAt    DateTime     @default(now())
  pass           DelegatePass @relation(fields: [passId], references: [id], onDelete: Cascade)
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  event          Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  checkedInBy    User?        @relation("CheckinBy", fields: [checkedInById], references: [id], onDelete: SetNull)

  @@unique([passId, eventId])
  @@index([registrationId])
}

model Notification {
  id             String           @id @default(cuid())
  userId         String
  eventId        String
  registrationId String?
  title          String
  message        String
  type           NotificationType @default(OTHER)
  read           Boolean          @default(false)
  createdAt      DateTime         @default(now())
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  event          Event            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registration   Registration?    @relation(fields: [registrationId], references: [id], onDelete: SetNull)

  @@index([userId, read])
}

model UserNotificationPreference {
  id                String           @id @default(cuid())
  userId            String
  notificationType  NotificationType
  emailEnabled      Boolean          @default(true)
  inAppEnabled      Boolean          @default(true)
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, notificationType])
}

model OrganizerConferenceConfig {
  id                   String               @id @default(cuid())
  eventId              String               @unique
  description          String?
  venue                String?
  logoImageUrl         String?
  bannerImageUrl       String?
  websiteUrl           String?
  instagramUrl         String?
  linkedinUrl          String?
  twitterUrl           String?
  brandPrimaryColor    String?
  brandSecondaryColor  String?
  paymentUpi           String?
  paymentBankHint      String?
  paymentNotesMarkdown String?
  event                Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  committees           CommitteeConfig[]
  pricingPhases        PricingPhaseConfig[]
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
}

model CommitteeConfig {
  id                String                    @id @default(cuid())
  organizerConfigId String
  name              String
  agenda            String
  type              String?
  chairName         String?
  chairEmail        String?
  seatCount         Int
  basePrice         Decimal?                  @db.Decimal(12, 2)
  visibility        CommitteeVisibility       @default(PUBLIC)
  organizerConfig   OrganizerConferenceConfig @relation(fields: [organizerConfigId], references: [id], onDelete: Cascade)
  questions         ApplicationQuestion[]
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt
}

model ApplicationQuestion {
  id          String           @id @default(cuid())
  committeeId String?
  label       String
  type        String
  required    Boolean          @default(false)
  optionsJson String?
  committee   CommitteeConfig? @relation(fields: [committeeId], references: [id], onDelete: Cascade)
  answers     ApplicationAnswer[]
  createdAt   DateTime         @default(now())
}

model ApplicationAnswer {
  id             String              @id @default(cuid())
  registrationId String
  questionId     String
  valueJson      String
  registration   Registration        @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  question       ApplicationQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([registrationId, questionId])
  @@index([registrationId])
}

model PricingPhaseConfig {
  id                 String                    @id @default(cuid())
  organizerConfigId  String
  name               String
  startDate          DateTime
  endDate            DateTime
  basePrice          Decimal                @db.Decimal(12, 2)
  committeePriceJson String?
  organizerConfig    OrganizerConferenceConfig @relation(fields: [organizerConfigId], references: [id], onDelete: Cascade)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  eventId     String?
  action      String
  entity      String
  entityId    String
  before      Json?
  after       Json?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())
  actor       User     @relation(fields: [actorUserId], references: [id], onDelete: Cascade)
  event       Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([actorUserId])
  @@index([eventId])
  @@index([entity, entityId])
}

model RateLimitBucket {
  id          String   @id @default(cuid())
  key         String
  windowStart DateTime
  count       Int      @default(0)

  @@unique([key, windowStart])
  @@index([key])
}

model ConferenceAward {
  id             String   @id @default(cuid())
  eventId        String
  category       String
  prizeTitle     String?
  sponsorLogoUrl String?
  description    String?
  createdAt      DateTime @default(now())
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
}

model ConferenceReview {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  rating    Int
  comment   String?
  status    String   @default("pending")
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
}

model Delegation {
  id           String             @id @default(cuid())
  eventId      String
  inviteToken  String             @unique
  name         String?
  ownerUserId  String
  createdAt    DateTime           @default(now())
  event        Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  owner        User               @relation("DelegationOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  members      DelegationMember[]

  @@index([eventId])
}

model DelegationMember {
  id           String     @id @default(cuid())
  delegationId String
  userId       String
  role         String?
  joinedAt     DateTime   @default(now())
  delegation   Delegation @relation(fields: [delegationId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([delegationId, userId])
}
